#!hexa strict
// hexa-bot/verify/real_limits_anchor.hexa — real-limits-first anchor.
//
// Per LATTICE_POLICY.md §1.3 rule 2: each project's verify must use at
// least one anchor from §1.2 (Shannon · Kolmogorov · Bekenstein · c · ℏ ·
// k · Stefan-Boltzmann · Carnot · ASML throughput · ERCOT · etc.) and
// at least one engineering/industry threshold.
//
// hexa-bot's real-limits audit lives in LIMIT_BREAKTHROUGH.md (Wave M,
// 2026-05-12). This script confirms that file is present and references
// the canonical robot-substrate HARD walls (H1–H10) so any agent has a
// pointer from verify→audit.
//
// Honesty: no value here is computed against the n=6 lattice. Each constant
// is sourced from Valiant 1984 / Madry 2018 / Bylander 1994 / Bernstein 2002
// / Boston Dynamics & Unitree public specs / HELM 2024 as cited in
// LIMIT_BREAKTHROUGH.md.

let HOME = env("HOME")
let HEXA_BOT_ROOT_ENV = env("HEXA_BOT_ROOT")

fn shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _resolve_root() -> str {
    if HEXA_BOT_ROOT_ENV.len() > 0 { return HEXA_BOT_ROOT_ENV }
    let oldpwd = env("OLDPWD")
    if oldpwd.len() > 0 {
        let t = exec("[ -f " + shq(oldpwd) + "/hexa.toml ] && echo y || echo n").trim()
        if t == "y" { return oldpwd }
    }
    let pwd = env("PWD")
    if pwd.len() > 0 {
        let t = exec("[ -f " + shq(pwd) + "/hexa.toml ] && echo y || echo n").trim()
        if t == "y" { return pwd }
    }
    return HOME + "/core/hexa-bot"
}

fn _file_exists(p: str) -> bool {
    let r = exec("[ -f " + shq(p) + " ] && echo yes || echo no").trim()
    return r == "yes"
}

fn _file_contains(p: str, needle: str) -> bool {
    let cmd = "grep -F " + shq(needle) + " " + shq(p) + " >/dev/null 2>&1 && echo yes || echo no"
    let r = exec(cmd).trim()
    return r == "yes"
}

fn main() {
    let root = _resolve_root()
    println("hexa-bot/verify/real_limits_anchor — real-limits-first check")
    println("  root: " + root)
    println("")
    println("  policy: LATTICE_POLICY §1.3 rule 2 — at least 1 real limit anchor required")
    println("  source: LIMIT_BREAKTHROUGH.md (Wave M, robot-substrate audit)")
    println("")

    let mut ok = 0
    let mut bad = 0

    // 1. Audit file must exist.
    let audit = root + "/LIMIT_BREAKTHROUGH.md"
    if _file_exists(audit) {
        println("  [PASS] LIMIT_BREAKTHROUGH.md present")
        ok = ok + 1
    } else {
        println("  [FAIL] LIMIT_BREAKTHROUGH.md missing (abs: " + audit + ")")
        bad = bad + 1
    }

    // 2. Audit must reference canonical robot-substrate HARD walls.
    //    Each anchor is a sourced HARD/SOFT wall from LIMIT_BREAKTHROUGH.md §2.
    let anchors = [
        ["Motor torque density (BLDC ~10–50 Nm/kg)",      "Motor torque density"],  // H1
        ["Battery energy density (~300 Wh/kg Li-ion)",     "Battery energy density"], // H2
        ["PAC-learning sample complexity (Valiant 1984)",  "Valiant"],               // H5
        ["Adversarial robustness (Madry 2018)",            "Madry"],                 // H6
        ["STRIPS planning PSPACE-complete (Bylander 1994)", "Bylander"],             // H7
        ["DEC-POMDP NEXP-complete (Bernstein 2002)",       "Bernstein"],             // H8
        ["Sensor noise floor (kT + shot noise)",           "Sensor noise floor"],    // H9
        ["LLM hallucination floor (HELM)",                 "HELM"],                  // S4
    ]
    for a in anchors {
        let label = a[0]
        let needle = a[1]
        if _file_contains(audit, needle) {
            println("  [PASS] anchor referenced: " + label)
            ok = ok + 1
        } else {
            println("  [FAIL] anchor missing: " + label + " (needle: '" + needle + "')")
            bad = bad + 1
        }
    }

    //    Per LATTICE_POLICY §3.3 + §1.3 rule 4, lattice-fit on external entities
    //    is forbidden. Confirm audit names the canonical vendors and disclaims AGI.
    let externals = [
        ["Boston Dynamics Spot / Unitree B2 spec sheets (public)",  "Boston Dynamics"],
        ["Unitree (B2 quadruped public specs)",                     "Unitree"],
        ["NO AGI claim",                                            "NO AGI"],
        ["No n=6 magic (motor density / hallucination / DEC-POMDP)", "No n=6 magic"],
    ]
    for u in externals {
        let label = u[0]
        let needle = u[1]
        if _file_contains(audit, needle) {
            println("  [PASS] honest-scope caveat preserved: " + label)
            ok = ok + 1
        } else {
            println("  [FAIL] honest-scope caveat MISSING: " + label)
            bad = bad + 1
        }
    }

    println("")
    println("  anchors verified: " + str(ok) + "  failures: " + str(bad))
    if bad > 0 {
        println("__HEXA_BOT_REAL_LIMITS_ANCHOR__ FAIL")
        exit(1)
    }
    println("__HEXA_BOT_REAL_LIMITS_ANCHOR__ PASS")
}
