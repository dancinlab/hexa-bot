#!hexa strict
// hexa-bot/verify/closure_consistency.hexa — scoreboard cross-check.
//
// Confirms three sources agree on the 4-verb count:
//   1. cli/hexa-bot.hexa SPEC_* constants (registry of record — 4 SPEC paths)
//   2. hexa.toml [closure] verbs_total / verbs_spec
//   3. README.md badge "verbs-4_spec" (or compatible)
//
// Per LATTICE_POLICY §1.3 rule 4: this is *internal* self-consistency
// (own substrate's own scoreboard), NOT a claim about external entities.
// External robotics vendors (Boston Dynamics, Tesla Optimus, Agility
// Robotics, Apptronik, Unitree) use THEIR OWN specs.

let HOME = env("HOME")
let HEXA_BOT_ROOT_ENV = env("HEXA_BOT_ROOT")

fn shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _resolve_root() -> str {
    if HEXA_BOT_ROOT_ENV.len() > 0 { return HEXA_BOT_ROOT_ENV }
    let oldpwd = env("OLDPWD")
    if oldpwd.len() > 0 {
        let t = exec("[ -f " + shq(oldpwd) + "/hexa.toml ] && echo y || echo n").trim()
        if t == "y" { return oldpwd }
    }
    let pwd = env("PWD")
    if pwd.len() > 0 {
        let t = exec("[ -f " + shq(pwd) + "/hexa.toml ] && echo y || echo n").trim()
        if t == "y" { return pwd }
    }
    return HOME + "/core/hexa-bot"
}

// Count SPEC_* verb-path constants in cli/hexa-bot.hexa (one line each).
// Match `let SPEC_<VERB> = SPEC_DIR + ...` — excludes the bare `SPEC_DIR` binding.
fn _count_cli_spec_paths(root: str) -> int {
    let cli = root + "/cli/hexa-bot.hexa"
    let raw = exec("grep -cE '^let SPEC_[A-Z_]+ *= SPEC_DIR' " + shq(cli)).trim()
    if raw.len() == 0 { return -1 }
    return int(raw)
}

// Count module spec entries in hexa.toml [modules] spec = [...].
fn _count_toml_modules(root: str) -> int {
    let toml = root + "/hexa.toml"
    // Lines inside spec = [...] that look like "    \"<path>.md\","
    let raw = exec("awk '/^spec *= *\\[/{f=1;next} f && /^\\]/{f=0} f && /\\.md/{c++} END{print c+0}' " + shq(toml)).trim()
    if raw.len() == 0 { return -1 }
    return int(raw)
}

fn _toml_int(root: str, key: str) -> int {
    let toml = root + "/hexa.toml"
    let cmd = "awk -F'=' '/^" + key + " *=/ {gsub(/[^0-9]/,\"\",$2); print $2; exit}' " + shq(toml)
    let raw = exec(cmd).trim()
    if raw.len() == 0 { return -1 }
    return int(raw)
}

fn _readme_badge_count(root: str) -> int {
    let readme = root + "/README.md"
    let cmd = "grep -oE 'verbs-[0-9]+' " + shq(readme) + " | head -1 | grep -oE '[0-9]+'"
    let raw = exec(cmd).trim()
    if raw.len() == 0 { return -1 }
    return int(raw)
}

fn _file_contains(p: str, needle: str) -> bool {
    let cmd = "grep -F " + shq(needle) + " " + shq(p) + " >/dev/null 2>&1 && echo yes || echo no"
    return exec(cmd).trim() == "yes"
}

fn main() {
    let root = _resolve_root()
    println("hexa-bot/verify/closure_consistency — scoreboard cross-check")
    println("  root: " + root)
    println("")

    let mut ok = 0
    let mut bad = 0

    let cli_n = _count_cli_spec_paths(root)
    let toml_modules = _count_toml_modules(root)
    let toml_total = _toml_int(root, "verbs_total")
    let toml_spec = _toml_int(root, "verbs_spec")
    let readme_n = _readme_badge_count(root)

    println("  cli/hexa-bot.hexa SPEC_* paths:    " + str(cli_n))
    println("  hexa.toml [modules] spec entries:  " + str(toml_modules))
    println("  hexa.toml verbs_total:             " + str(toml_total))
    println("  hexa.toml verbs_spec:              " + str(toml_spec))
    println("  README badge verbs-N:              " + str(readme_n))
    println("")

    if cli_n == 4 {
        println("  [PASS] CLI registry has 4 SPEC paths")
        ok = ok + 1
    } else {
        println("  [FAIL] CLI registry has " + str(cli_n) + " SPEC paths (expected 4)")
        bad = bad + 1
    }
    if toml_modules == 4 {
        println("  [PASS] hexa.toml [modules] has 4 spec entries")
        ok = ok + 1
    } else {
        println("  [FAIL] hexa.toml [modules] has " + str(toml_modules) + " spec entries (expected 4)")
        bad = bad + 1
    }
    if toml_total == 4 {
        println("  [PASS] hexa.toml verbs_total = 4")
        ok = ok + 1
    } else {
        println("  [FAIL] hexa.toml verbs_total = " + str(toml_total))
        bad = bad + 1
    }
    if toml_spec == 4 {
        println("  [PASS] hexa.toml verbs_spec = 4")
        ok = ok + 1
    } else {
        println("  [FAIL] hexa.toml verbs_spec = " + str(toml_spec))
        bad = bad + 1
    }
    if readme_n == 4 {
        println("  [PASS] README badge verbs-4")
        ok = ok + 1
    } else {
        println("  [FAIL] README badge verbs-" + str(readme_n) + " (expected 4)")
        bad = bad + 1
    }

    // Standard policy artifacts must be present.
    let must = ["LATTICE_POLICY.md", "LIMIT_BREAKTHROUGH.md", "AGENTS.md", "hexa.toml", "README.md", "LICENSE", "CITATION.cff"]
    for f in must {
        let abs_f = root + "/" + f
        let cmd = "[ -f " + shq(abs_f) + " ] && echo y || echo n"
        if exec(cmd).trim() == "y" {
            println("  [PASS] standard artifact: " + f)
            ok = ok + 1
        } else {
            println("  [FAIL] standard artifact missing: " + f)
            bad = bad + 1
        }
    }

    // AGENTS.md must register LATTICE_POLICY + LIMIT_BREAKTHROUGH.
    let agents = root + "/AGENTS.md"
    if _file_contains(agents, "LATTICE_POLICY.md") {
        println("  [PASS] AGENTS.md registers LATTICE_POLICY.md")
        ok = ok + 1
    } else {
        println("  [FAIL] AGENTS.md does not register LATTICE_POLICY.md")
        bad = bad + 1
    }
    if _file_contains(agents, "LIMIT_BREAKTHROUGH.md") {
        println("  [PASS] AGENTS.md registers LIMIT_BREAKTHROUGH.md")
        ok = ok + 1
    } else {
        println("  [FAIL] AGENTS.md does not register LIMIT_BREAKTHROUGH.md")
        bad = bad + 1
    }

    println("")
    println("  passed: " + str(ok) + "  failed: " + str(bad))
    if bad > 0 {
        println("__HEXA_BOT_CLOSURE_CONSISTENCY__ FAIL")
        exit(1)
    }
    println("__HEXA_BOT_CLOSURE_CONSISTENCY__ PASS")
}
